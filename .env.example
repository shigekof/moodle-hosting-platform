# Shared infrastructure environment variables
# Copy this file to .env and fill in real values before running docker compose up.
# NEVER commit .env to version control.

# Let's Encrypt — email to receive certificate expiry warnings (applies to all client domains)
ACME_EMAIL=admin@example.com

# MariaDB root password — used only by healthcheck probe and add-client.sh
MARIADB_ROOT_PASSWORD=CHANGE_ME_ROOT

# MariaDB shared user password — must match MOODLE_DATABASE_PASSWORD in all clients/.env files
MARIADB_PASSWORD=CHANGE_ME_DB

# Redis persistence (no = RDB snapshots only, yes = AOF enabled for stronger durability)
REDIS_AOF_ENABLED=no
