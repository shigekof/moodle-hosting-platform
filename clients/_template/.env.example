# Per-client environment variables
# This file is auto-generated by scripts/add-client.sh.
# Copy this as a reference only — never fill real values here.
# Real credentials are written to clients/{name}/.env (gitignored).

# Client identity
CLIENT_NAME=CHANGE_ME
CLIENT_DOMAIN=CHANGE_ME.example.com

# Moodle admin account
MOODLE_USERNAME=admin
MOODLE_PASSWORD=CHANGE_ME
MOODLE_EMAIL=admin@CHANGE_ME.example.com
MOODLE_SITE_NAME=CHANGE_ME Learning

# Moodle public URL — must be HTTPS in production (required by custom image entrypoint)
MOODLE_WWWROOT=https://CHANGE_ME.example.com

# Database — shared MariaDB container, per-client database
MOODLE_DATABASE_HOST=mariadb
MOODLE_DATABASE_PORT_NUMBER=3306
MOODLE_DATABASE_USER=moodle
MOODLE_DATABASE_PASSWORD=CHANGE_ME
MOODLE_DATABASE_NAME=moodle_CHANGE_ME

# Redis session handler with per-client key prefix (T027b/T027e)
MOODLE_REDIS_HOST=redis
MOODLE_REDIS_PORT=6379
MOODLE_SESSION_REDIS_PREFIX=moodle_CHANGE_ME_session_
