# Local development environment variables
# Copy to .env.local and fill in values before running docker compose.
# NEVER commit .env.local to version control.

# MariaDB
MARIADB_ROOT_PASSWORD=localroot
MARIADB_PASSWORD=localpass

# Moodle admin account
MOODLE_USERNAME=admin
MOODLE_PASSWORD=Admin1234!
MOODLE_EMAIL=admin@example.com
MOODLE_SITE_NAME=Local Moodle

# Moodle public URL — must match what browser uses to reach Moodle
MOODLE_WWWROOT=http://localhost:8080
